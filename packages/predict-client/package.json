{
  "name": "@deepbookie/predict-client",
  "version": "0.1.0",
  "description": "The first DeepBook Predict TypeScript client — unsigned PTB builders, indexer readers, and SVI vol-surface math for Sui's DeepBook Predict prediction market.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=1 vitest run"
  },
  "dependencies": {
    "@mysten/sui": "^2.19.0"
  },
  "author": "blockchainoracle <blockchainoracle.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/deepbookie.git",
    "directory": "packages/predict-client"
  },
  "homepage": "https://deepbookie.vercel.app",
  "bugs": {
    "url": "https://github.com/Blockchain-Oracle/deepbookie/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sui",
    "deepbook",
    "deepbook-predict",
    "prediction-market",
    "defi",
    "ptb",
    "svi",
    "prediction"
  ]
}
