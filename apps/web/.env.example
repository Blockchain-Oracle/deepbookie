# === DeepBookie web — environment (copy to .env.local; .env.local is gitignored) ===

# Faucet operator wallet: holds testnet dUSDC + a little SUI; dispenses small grants to new users.
# This is the ONE server-held key — an operator funding wallet, never a user trading key.
FAUCET_OPERATOR_KEY=suiprivkey1...

# AI model provider (Phase 4). MODEL_PROVIDER=anthropic|openai; each provider reads its own key.
MODEL_PROVIDER=anthropic
MODEL_ID=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Database (Phase 6 — Neon Postgres) for chat-session transcripts.
DATABASE_URL=postgres://user:pass@host/db

# Enoki zkLogin — "Sign in with Google" (Slice A: login only, no sponsorship).
# PUBLIC values (safe to inline in the browser). Get them from the Enoki Developer Portal
# (portal.enoki.mystenlabs.com): create a project, add Google as an auth provider with your
# Google OAuth Client ID, and copy the enoki_public_* key. Both must be set for the Google
# entry to appear in the ConnectButton modal; if unset the app stays extension-wallet-only.
# NOTE: the key + Google client are ORIGIN-LOCKED — add this app's origin to the Enoki portal
# allowed-origins AND the Google client's authorized JS origins, or Google sign-in will error.
NEXT_PUBLIC_ENOKI_API_KEY=enoki_public_...
NEXT_PUBLIC_ENOKI_GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# Slice B — gasless (Enoki sponsorship). When NEXT_PUBLIC_SPONSOR_ENABLED=true, writes route through
# /api/sponsor/* so users need NO SUI for gas. Requires ENOKI_PRIVATE_KEY at runtime (server) + the
# Enoki portal: Sponsored Transactions enabled with a funded gas budget. Leave false until that's set.
NEXT_PUBLIC_SPONSOR_ENABLED=false
ENOKI_PRIVATE_KEY=enoki_private_...

# Optional
LOG_LEVEL=info
